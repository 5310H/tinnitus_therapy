JavaScript: Decorrelated Engine

`javascript
class DecorrelatedTherapyEngine {
    constructor() {
        this.audioContext = null;
        this.leftSource = null;
        this.rightSource = null;
        this.leftGain = null;
        this.rightGain = null;
        this.merger = null;
        this.masterGain = null;
        this.isPlaying = false;
        this.decorrelationLevel = 1.0;
    }

    initialize() {
        this.audioContext = new (window.AudioContext
                             || window.webkitAudioContext)();

        this.merger = this.audioContext.createChannelMerger(2);

        this.leftGain = this.audioContext.createGain();
        this.rightGain = this.audioContext.createGain();

        this.masterGain = this.audioContext.createGain();
        this.masterGain.gain.value = 0.3;

        this.leftGain.connect(this.merger, 0, 0);
        this.rightGain.connect(this.merger, 0, 1);
        this.merger.connect(this.masterGain);
        this.masterGain.connect(this.audioContext.destination);
    }

    play(noiseType) {
        if (!this.audioContext) this.initialize();
        if (this.audioContext.state === 'suspended') {
            this.audioContext.resume();
        }

        this.stop();

        const bufferDuration = 4;
        const generateFn = this.getGeneratorFunction(noiseType);

        const leftBuffer = generateFn(
            this.audioContext, bufferDuration);
        const rightBuffer = generateFn(
            this.audioContext, bufferDuration);

        if (this.decorrelationLevel < 1.0) {
            this.mixBuffers(leftBuffer, rightBuffer,
                          this.decorrelationLevel);
        }

        this.leftSource =
            this.audioContext.createBufferSource();
        this.leftSource.buffer = leftBuffer;
        this.leftSource.loop = true;
        this.leftSource.connect(this.leftGain);

        this.rightSource =
            this.audioContext.createBufferSource();
        this.rightSource.buffer = rightBuffer;
        this.rightSource.loop = true;
        this.rightSource.connect(this.rightGain);

        const startTime = this.audioContext.currentTime + 0.01;
        this.leftSource.start(startTime);
        this.rightSource.start(startTime);
        this.isPlaying = true;
    }

    getGeneratorFunction(noiseType) {
        switch (noiseType) {
            case 'white': return generateWhiteNoise;
            case 'brown': return generateBrownNoise;
            case 'pink':
            default:      return generatePinkNoise;
        }
    }

    mixBuffers(bufferA, bufferB, decorrelation) {
        const dataA = bufferA.getChannelData(0);
        const dataB = bufferB.getChannelData(0);
        const blend = 1 - decorrelation;

        for (let i = 0; i < dataA.length; i++) {
            const avg = (dataA[i] + dataB[i]) / 2;
            dataA[i] = dataA[i]  decorrelation + avg  blend;
            dataB[i] = dataB[i]  decorrelation + avg  blend;
        }
    }

    setBalance(value) {
        const normalized = value / 100;
        const leftLevel = Math.cos(
            (normalized + 1) * Math.PI / 4);
        const rightLevel = Math.sin(
            (normalized + 1) * Math.PI / 4);

        this.leftGain.gain.setTargetAtTime(
            leftLevel, this.audioContext.currentTime, 0.05);
        this.rightGain.gain.setTargetAtTime(
            rightLevel, this.audioContext.currentTime, 0.05);
    }

    setDecorrelation(percent) {
        this.decorrelationLevel = percent / 100;
        if (this.isPlaying) {
            const currentType = document.querySelector(
                'input[name="noiseColor"]:checked').value;
            this.play(currentType);
        }
    }

    setVolume(percent) {
        if (this.masterGain) {
            this.masterGain.gain.setTargetAtTime(
                percent / 100,
                this.audioContext.currentTime,
                0.05
            );
        }
    }

    stop() {
        [this.leftSource, this.rightSource].forEach(src => {
            if (src) {
                try { src.stop(); } catch (e) {}
                src.disconnect();
            }
        });
        this.leftSource = null;
        this.rightSource = null;
        this.isPlaying = false;
    }
}
`

