JavaScript: Noise Generation Algorithms

White Noise

White noise has equal power at every frequency. It is generated by filling an audio buffer with uniformly distributed random samples:

`javascript
function generateWhiteNoise(audioContext, durationSeconds) {
    const sampleRate = audioContext.sampleRate;
    const bufferSize = sampleRate * durationSeconds;
    const buffer = audioContext.createBuffer(1, bufferSize, sampleRate);
    const channelData = buffer.getChannelData(0);

    for (let i = 0; i < bufferSize; i++) {
        channelData[i] = Math.random() * 2 - 1;
    }

    return buffer;
}
`

Pink Noise (Voss-McCartney Algorithm)

Pink noise has a spectral density that decreases at 3 dB per octave. The Voss-McCartney algorithm uses multiple random generators updated at different rates to approximate the −3 dB/octave slope efficiently:

`javascript
function generatePinkNoise(audioContext, durationSeconds) {
    const sampleRate = audioContext.sampleRate;
    const bufferSize = sampleRate * durationSeconds;
    const buffer = audioContext.createBuffer(1, bufferSize, sampleRate);
    const channelData = buffer.getChannelData(0);

    const NUM_ROWS = 16;
    let runningSum = 0;
    const rows = new Float32Array(NUM_ROWS);

    for (let i = 0; i < NUM_ROWS; i++) {
        rows[i] = Math.random() * 2 - 1;
        runningSum += rows[i];
    }

    for (let i = 0; i < bufferSize; i++) {
        let n = i;
        let numZeros = 0;
        if (n > 0) {
            while ((n & 1) === 0) {
                numZeros++;
                n >>= 1;
            }
        }

        const rowIndex = numZeros % NUM_ROWS;
        runningSum -= rows[rowIndex];
        rows[rowIndex] = Math.random() * 2 - 1;
        runningSum += rows[rowIndex];

        channelData[i] = runningSum / NUM_ROWS;
    }

    return buffer;
}
`

Brown Noise (Brownian / Red Noise)

Brown noise is generated by integrating white noise — each sample is the previous sample plus a small random step. A leaky integrator prevents DC drift:

`javascript
function generateBrownNoise(audioContext, durationSeconds) {
    const sampleRate = audioContext.sampleRate;
    const bufferSize = sampleRate * durationSeconds;
    const buffer = audioContext.createBuffer(1, bufferSize, sampleRate);
    const channelData = buffer.getChannelData(0);

    let lastSample = 0;
    const leak = 0.995;

    for (let i = 0; i < bufferSize; i++) {
        const whiteStep = Math.random() * 2 - 1;
        lastSample = (lastSample  leak) + (whiteStep  0.1);
        channelData[i] = Math.max(-1, Math.min(1, lastSample * 3.5));
    }

    return buffer;
}
`

Audio Engine: Playback & Controls

`javascript
class SoundTherapyEngine {
    constructor() {
        this.audioContext = null;
        this.sourceNode = null;
        this.gainNode = null;
        this.filterNode = null;
        this.isPlaying = false;
        this.timerId = null;
    }

    initialize() {
        this.audioContext = new (window.AudioContext
                             || window.webkitAudioContext)();
        this.gainNode = this.audioContext.createGain();
        this.filterNode = this.audioContext.createBiquadFilter();
        this.filterNode.type = 'lowpass';
        this.filterNode.frequency.value = 22050;

        this.filterNode.connect(this.gainNode);
        this.gainNode.connect(this.audioContext.destination);
    }

    play(noiseType) {
        if (!this.audioContext) this.initialize();
        if (this.audioContext.state === 'suspended') {
            this.audioContext.resume();
        }

        this.stop();

        const bufferDuration = 4;
        let buffer;
        switch (noiseType) {
            case 'white':
                buffer = generateWhiteNoise(
                    this.audioContext, bufferDuration);
                break;
            case 'brown':
                buffer = generateBrownNoise(
                    this.audioContext, bufferDuration);
                break;
            case 'pink':
            default:
                buffer = generatePinkNoise(
                    this.audioContext, bufferDuration);
        }

        this.sourceNode = this.audioContext.createBufferSource();
        this.sourceNode.buffer = buffer;
        this.sourceNode.loop = true;
        this.sourceNode.connect(this.filterNode);
        this.sourceNode.start();
        this.isPlaying = true;
    }

    setVolume(percent) {
        if (this.gainNode) {
            this.gainNode.gain.setTargetAtTime(
                percent / 100,
                this.audioContext.currentTime,
                0.05
            );
        }
    }

    setRolloff(percent) {
        if (this.filterNode) {
            const minFreq = 200;
            const maxFreq = 22050;
            const freq = maxFreq * Math.pow(
                minFreq / maxFreq, percent / 100);
            this.filterNode.frequency.setTargetAtTime(
                freq,
                this.audioContext.currentTime,
                0.1
            );
        }
    }

    fadeOut(durationSeconds) {
        if (this.gainNode && this.isPlaying) {
            this.gainNode.gain.setTargetAtTime(
                0,
                this.audioContext.currentTime,
                durationSeconds / 4
            );
            setTimeout(() => this.stop(),
                       durationSeconds * 1000);
        }
    }

    stop() {
        if (this.sourceNode) {
            try { this.sourceNode.stop(); } catch (e) {}
            this.sourceNode.disconnect();
            this.sourceNode = null;
        }
        if (this.timerId) {
            clearTimeout(this.timerId);
            this.timerId = null;
        }
        this.isPlaying = false;
    }

    startTimer(minutes) {
        if (minutes <= 0) return;
        const fadeTime = 10;
        const ms = (minutes  60 - fadeTime)  1000;
        this.timerId = setTimeout(() => {
            this.fadeOut(fadeTime);
        }, ms);
    }
}
`

